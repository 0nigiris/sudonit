---
/**
 * BaseLayout — the document shell every page uses.
 * Handles <head>, fonts, SEO basics, header/footer, skip link, locale.
 */
import '../styles/base.css';
import { type Locale, SITE, LOCALES, DEFAULT_LOCALE } from '../data/site';
import { localePath, barePath } from '../lib/paths';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileStickyBar from '../components/MobileStickyBar.astro';

interface Props {
  locale: Locale;
  title: string;
  description?: string;
  noindex?: boolean; // error/utility pages (e.g. 404) — no canonical/hreflang
}
const { locale, title, description = '', noindex = false } = Astro.props;
const fullTitle = title ? `${title} — ${SITE.name}` : SITE.name;

// Open Graph wants language_TERRITORY, not the bare code used by <html lang>.
const OG_LOCALE: Record<Locale, string> = { ru: 'ru_RU', en: 'en_US', es: 'es_ES' };

// Absolute URLs for SEO / social. Resolved against `site` in astro.config —
// set that to the real domain before launch and these become correct.
// Skipped entirely for noindex pages (a 404 must not claim a canonical URL).
const bare = barePath(Astro.url.pathname);
const abs = (path: string) => (Astro.site ? new URL(path, Astro.site).href : undefined);
const canonical = noindex ? undefined : abs(localePath(locale, bare));
const ogImage = abs('/og-card.png');
const alternates = noindex
  ? []
  : LOCALES.map((l) => ({ hreflang: l, href: abs(localePath(l, bare)) }));
const xDefault = noindex ? undefined : abs(localePath(DEFAULT_LOCALE, bare));
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex" />}

    {canonical && <link rel="canonical" href={canonical} />}
    {/* Trilingual SEO: tell crawlers about each locale of this same page. */}
    {
      alternates.map(
        (a) => a.href && <link rel="alternate" hreflang={a.hreflang} href={a.href} />,
      )
    }
    {xDefault && <link rel="alternate" hreflang="x-default" href={xDefault} />}

    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={OG_LOCALE[locale]} />
    {canonical && <meta property="og:url" content={canonical} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}

    {/* Twitter/X large-image card — reuses the same OG card. */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <meta name="theme-color" content="#15130f" />

    {/* Preload the display face (Geologica) — it's the hero/LCP element.
        RU is the primary language, so preload both Cyrillic + Latin display subsets. */}
    <link rel="preload" href={`/fonts/geologica-${locale === 'ru' ? 'cyrillic' : 'latin'}.woff2`}
      as="font" type="font/woff2" crossorigin />

    {/* Arm reveal-on-scroll BEFORE paint, so content is only ever hidden when
        JS is actually running (no-JS users get the fully-visible baseline,
        and there's no flash of hidden content). */}
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body>
    {/* Decorative gutter star-field — see the script + #petal-field rule in base.css */}
    <canvas id="petal-field" aria-hidden="true"></canvas>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header locale={locale} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
    <MobileStickyBar locale={locale} />

    <script>
      // Reveal-on-scroll: the only motion island. Reveals each block once as it
      // enters view; under reduced-motion or no IntersectionObserver, everything
      // is shown immediately. transform/opacity only — kept tiny for mobile.
      const els = document.querySelectorAll('[data-reveal], [data-reveal-group]');
      const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
      const showAll = () => els.forEach((el) => el.classList.add('is-visible'));

      try {
        if (reduce || !('IntersectionObserver' in window)) {
          showAll();
        } else {
          const io = new IntersectionObserver(
            (entries, obs) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  obs.unobserve(entry.target);
                }
              }
            },
            { rootMargin: '0px 0px -8% 0px', threshold: 0.12 }
          );
          els.forEach((el) => {
            io.observe(el);
            // A11y: if keyboard focus lands inside a block before it has scrolled
            // into view, reveal it immediately so focus is never on hidden content.
            el.addEventListener(
              'focusin',
              () => {
                el.classList.add('is-visible');
                io.unobserve(el);
              },
              { once: true }
            );
          });
        }
      } catch {
        // Never leave content hidden if anything goes wrong.
        showAll();
      }
    </script>

    <script>
      // Decorative gutter star-field. Tiny 4-pointed sparkles drift downward like
      // falling petals through the empty side margins on wide screens. One fixed
      // canvas, one rAF loop, capped particle count — atmosphere, never the point.
      (() => {
        const cv = document.getElementById('petal-field');
        if (!(cv instanceof HTMLCanvasElement)) return;
        const ctx = cv.getContext('2d');
        if (!ctx) return;

        const wide = matchMedia('(min-width: 1100px)');
        const reduce = matchMedia('(prefers-reduced-motion: reduce)');

        let W = 0, H = 0, dpr = 1;
        let stars = [];
        let raf = 0;
        let last = 0;

        // Side bands the stars live in. Slightly wider than the visual gutter so
        // the field reaches a little toward the centre — but never behind content.
        const BAND = 0.19;

        const rnd = (a, b) => a + Math.random() * (b - a);

        function spawn(initial) {
          const left = Math.random() < 0.5;
          const bw = W * BAND;
          const x = left ? rnd(0, bw) : rnd(W - bw, W);
          return {
            x,
            y: initial ? rnd(0, H) : rnd(-40, -8),
            r: rnd(2.2, 6.5),
            vy: rnd(14, 34),          // px/sec, downward
            sway: rnd(8, 26),         // horizontal sine amplitude
            sw: rnd(0.3, 0.9),        // sway speed
            ph: rnd(0, Math.PI * 2),  // sway phase
            rot: rnd(0, Math.PI * 2),
            vr: rnd(-0.5, 0.5),       // rotation speed
            a: rnd(0.1, 0.3),         // alpha
          };
        }

        // 4-pointed concave sparkle: 8 vertices alternating outer/inner radius.
        function drawStar(s) {
          const inner = s.r * 0.32;
          ctx.save();
          ctx.translate(s.x + Math.sin(s.ph) * s.sway, s.y);
          ctx.rotate(s.rot);
          ctx.beginPath();
          for (let i = 0; i < 8; i++) {
            const rad = i % 2 === 0 ? s.r : inner;
            const ang = (Math.PI / 4) * i;
            const px = Math.cos(ang) * rad;
            const py = Math.sin(ang) * rad;
            i === 0 ? ctx.moveTo(px, py) : ctx.lineTo(px, py);
          }
          ctx.closePath();
          ctx.fillStyle = 'rgba(255, 157, 77, ' + s.a + ')';
          ctx.fill();
          ctx.restore();
        }

        function render() {
          ctx.clearRect(0, 0, W, H);
          for (const s of stars) drawStar(s);
        }

        function resize() {
          dpr = Math.min(window.devicePixelRatio || 1, 2);
          W = window.innerWidth;
          H = window.innerHeight;
          cv.width = Math.round(W * dpr);
          cv.height = Math.round(H * dpr);
          cv.style.width = W + 'px';
          cv.style.height = H + 'px';
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          const count = Math.min(56, Math.round(W / 28));
          stars = Array.from({ length: count }, () => spawn(true));
        }

        function tick(now) {
          const dt = Math.min((now - last) / 1000, 0.05);
          last = now;
          for (const s of stars) {
            s.y += s.vy * dt;
            s.ph += s.sw * dt;
            s.rot += s.vr * dt;
            if (s.y - s.r > H) Object.assign(s, spawn(false));
          }
          render();
          raf = requestAnimationFrame(tick);
        }

        function start() {
          if (raf) return;
          last = performance.now();
          raf = requestAnimationFrame(tick);
        }
        function stop() {
          cancelAnimationFrame(raf);
          raf = 0;
        }

        let rt = 0;
        function onResize() {
          clearTimeout(rt);
          rt = window.setTimeout(() => {
            if (!wide.matches) { stop(); ctx.clearRect(0, 0, W, H); return; }
            resize();
            if (reduce.matches) render();
            else if (!document.hidden) start();
          }, 150);
        }

        function init() {
          if (!wide.matches) { stop(); ctx.clearRect(0, 0, W, H); return; }
          resize();
          if (reduce.matches) { render(); return; } // static single frame
          if (!document.hidden) start();
        }

        document.addEventListener('visibilitychange', () => {
          if (!wide.matches || reduce.matches) return;
          document.hidden ? stop() : start();
        });
        window.addEventListener('resize', onResize, { passive: true });
        (wide.addEventListener ? wide.addEventListener('change', init) : null);
        init();
      })();
    </script>

    {/* A small wink for the curious who open DevTools — harmless, invisible to everyone else. */}
    <script is:inline>
      console.log(
        '%cSudonit',
        'font:700 28px ui-monospace,monospace;color:#e8a33d'
      );
      console.log(
        '%cО, привет 👋  Раз ты здесь — значит, любопытный. Мне нравится.\n' +
          'Ремонт · репетиторство · проекты → youtube.com/@Sudo_0nigiri',
        'font:13px ui-monospace,monospace;color:#b9b2a6;line-height:1.5'
      );
    </script>
  </body>
</html>
