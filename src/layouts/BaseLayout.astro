---
/**
 * BaseLayout — the document shell every page uses.
 * Handles <head>, fonts, SEO basics, header/footer, skip link, locale.
 */
import '../styles/base.css';
import { type Locale, SITE } from '../data/site';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  locale: Locale;
  title: string;
  description?: string;
}
const { locale, title, description = '' } = Astro.props;
const fullTitle = title ? `${title} — ${SITE.name}` : SITE.name;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{fullTitle}</title>
    {description && <meta name="description" content={description} />}

    <meta property="og:title" content={fullTitle} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#15130f" />

    {/* Preload the display face (Geologica) — it's the hero/LCP element.
        RU is the primary language, so preload both Cyrillic + Latin display subsets. */}
    <link rel="preload" href={`/fonts/geologica-${locale === 'ru' ? 'cyrillic' : 'latin'}.woff2`}
      as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header locale={locale} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
