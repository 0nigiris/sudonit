---
/**
 * PageHero — shared hero for the dedicated service/project pages.
 * Back link ("← OniT") makes each page feel like its own destination, not a modal.
 */
import { type Locale, SITE } from '../data/site';
import { localePath } from '../lib/paths';
import PhotoFrame from './PhotoFrame.astro';

interface Props {
  locale: Locale;
  eyebrow: string;      // verb label
  tint: string;
  name: string;
  oneLine: string;
  statusLabel?: string; // "in progress" for projects
  photoId: string;
  ratio?: string;
}
const { locale, eyebrow, tint, name, oneLine, statusLabel, photoId, ratio = '3 / 2' } = Astro.props;
---

<header class="phero" style={`--tint:${tint}`}>
  <div class="container">
    <a class="phero__back" href={localePath(locale, '/')}>← {SITE.name}</a>
    {/* Above the fold = the LCP element; paint it instantly, no JS-gated fade. */}
    <div class="phero__grid">
      <div class="phero__text">
        <p class="phero__eyebrow">
          {eyebrow}{statusLabel && <em class="phero__status"> · {statusLabel}</em>}
        </p>
        <h1 class="phero__name">{name}</h1>
        <p class="phero__line">{oneLine}</p>
      </div>
      <PhotoFrame id={photoId} ratio={ratio} tint={tint} alt={name} placeholder={false} class="phero__photo" />
    </div>
  </div>
</header>

<style>
  .phero {
    padding-block: var(--space-5) var(--space-6);
    border-bottom: 1px solid var(--c-line);
  }
  .phero__back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    color: var(--c-muted);
    margin-bottom: var(--space-5);
    transition: color var(--dur-micro) var(--ease-settle);
  }
  .phero__back:hover {
    color: var(--c-text);
  }
  .phero__grid {
    display: grid;
    grid-template-columns: 1fr; /* text-only until the page photo exists */
    gap: var(--space-6);
    align-items: center;
  }
  /* Two columns only once a real photo is present. */
  .phero__grid:has(.photo) {
    grid-template-columns: 1.3fr 0.9fr;
  }
  .phero__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--tint);
    margin-bottom: var(--space-3);
  }
  .phero__status {
    color: var(--c-muted);
    font-style: normal;
  }
  .phero__name {
    font-size: var(--fs-display);
    line-height: var(--lh-tight);
    margin-bottom: var(--space-3);
  }
  .phero__line {
    font-size: var(--fs-lead);
    color: var(--c-text);
    max-width: 28ch;
  }
  @media (max-width: 900px) {
    .phero__grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .phero__photo {
      max-width: 480px;
    }
  }
</style>
