---
/**
 * Contact — the low-friction close. WhatsApp/Telegram primary, then a short
 * write-here form. The form posts to Formspree (static-friendly: no server),
 * which emails the message through. When the Telegram bot is live, only the
 * form's `action` needs to change — markup stays.
 * The one place the warm mark reaches full glow (static here; Phase 4 animates).
 */
import { type Locale } from '../../data/site';
import { homeT } from '../../i18n/home';
import { t } from '../../i18n/ui';
import { whatsappLink, emailLink, telegramLink, instagramLink, contact } from '../../data/contact';
import { SITE } from '../../data/site';
import WarmMark from '../WarmMark.astro';

interface Props { locale: Locale }
const { locale } = Astro.props;

// Where the form delivers. Swap this single URL for the Telegram-bot webhook later.
const FORM_ACTION = 'https://formspree.io/f/mbdabkdy';
// After submit, Formspree returns the visitor here with ?sent=1 so we can say thanks.
const nextUrl = Astro.site
  ? new URL(`${Astro.url.pathname}?sent=1#contact`, Astro.site).href
  : '?sent=1#contact';

// Self-contained form copy (kept local so it doesn't touch the typed i18n union).
const FORM_COPY: Record<Locale, {
  divider: string; name: string; email: string; message: string; send: string; sent: string;
}> = {
  ru: {
    divider: 'или напиши прямо здесь',
    name: 'Как тебя зовут?',
    email: 'твой@email.com',
    message: 'Что случилось? Опиши своими словами…',
    send: 'Отправить',
    sent: 'Спасибо! Сообщение ушло — отвечу как смогу.',
  },
  en: {
    divider: 'or write right here',
    name: 'Your name?',
    email: 'your@email.com',
    message: "What's going on? Describe it in your own words…",
    send: 'Send',
    sent: "Thanks! Your message is on its way — I'll reply as soon as I can.",
  },
  es: {
    divider: 'o escríbeme aquí mismo',
    name: '¿Cómo te llamas?',
    email: 'tu@email.com',
    message: '¿Qué pasó? Descríbelo con tus palabras…',
    send: 'Enviar',
    sent: '¡Gracias! Tu mensaje está en camino — te responderé en cuanto pueda.',
  },
};
const fc = FORM_COPY[locale];
---

<section class="section contact" id="contact">
  <div class="container contact__inner" data-reveal>
    <WarmMark size={40} glow={true} class="contact__mark" />
    <p class="eyebrow">{homeT(locale, 'contact.eyebrow')}</p>
    <h2 class="contact__title">{homeT(locale, 'contact.title')}</h2>
    <p class="contact__note">{homeT(locale, 'contact.note')}</p>

    <div class="contact__actions">
      <a class="cta cta--warm" href={whatsappLink()} target="_blank" rel="noopener noreferrer">
        {t(locale, 'contact.whatsapp')}
      </a>
      <a class="cta cta--ghost" href={telegramLink()} target="_blank" rel="noopener noreferrer">
        {t(locale, 'contact.telegram')}
      </a>
      <a class="cta cta--ghost" href={emailLink()}>
        {t(locale, 'contact.email')}
      </a>
    </div>

    <p class="contact__reply"><span class="contact__pulse" aria-hidden="true"></span>{homeT(locale, 'contact.reply')}</p>

    <p class="contact__divider"><span>{fc.divider}</span></p>

    {/* Thank-you note shown after Formspree redirects back with ?sent=1. */}
    <p class="contact__sent" data-contact-sent hidden>{fc.sent}</p>

    <form class="cform" action={FORM_ACTION} method="POST">
      <input type="hidden" name="_subject" value="Новая заявка с sudonit.com" />
      <input type="hidden" name="_next" value={nextUrl} />
      <div class="cform__row">
        <input class="cform__input" type="text" name="name" autocomplete="name"
          placeholder={fc.name} required />
        <input class="cform__input" type="email" name="email" autocomplete="email"
          placeholder={fc.email} required />
      </div>
      <textarea class="cform__input cform__msg" name="message" rows="4"
        placeholder={fc.message} required></textarea>
      <button class="cta cta--warm cform__send" type="submit">{fc.send}</button>
    </form>

    <div class="contact__social">
      <a href={instagramLink()} target="_blank" rel="noopener noreferrer">@{contact.instagram}</a>
      <span class="contact__dot" aria-hidden="true">·</span>
      <a href={contact.youtube} target="_blank" rel="noopener noreferrer">@{SITE.youtubeHandle}</a>
    </div>
  </div>
</section>

<style>
  .contact__inner {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .contact__mark {
    margin-bottom: var(--space-3);
  }
  .contact__title {
    font-size: var(--fs-h1);
    max-width: 18ch;
    margin-block: var(--space-2) var(--space-3);
    text-wrap: balance;
  }
  .contact__note {
    color: var(--c-muted);
    margin-bottom: var(--space-5);
  }
  .contact__actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    justify-content: center;
  }
  .contact__reply {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-3);
    font-size: var(--fs-small);
    color: var(--c-muted);
  }
  .contact__pulse {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: #4ad27a;
    box-shadow: 0 0 0 0 color-mix(in srgb, #4ad27a 70%, transparent);
    animation: contact-pulse 2.4s var(--ease-settle) infinite;
  }
  @keyframes contact-pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, #4ad27a 55%, transparent); }
    70% { box-shadow: 0 0 0 7px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }
  @media (prefers-reduced-motion: reduce) {
    .contact__pulse { animation: none; }
  }
  .contact__social {
    display: inline-flex;
    gap: var(--space-3);
    align-items: center;
    margin-top: var(--space-5);
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    color: var(--c-muted);
  }
  .contact__social a {
    color: var(--c-muted);
    transition: color var(--dur-micro) var(--ease-settle);
  }
  .contact__social a:hover {
    color: var(--c-text);
  }
  .contact__dot {
    opacity: 0.5;
  }

  /* "or write here" divider with hairlines either side. */
  .contact__divider {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    width: min(440px, 100%);
    margin: var(--space-6) auto var(--space-4);
    color: var(--c-muted);
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
  }
  .contact__divider::before,
  .contact__divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--c-line);
  }
  .contact__sent {
    width: min(440px, 100%);
    margin: 0 auto var(--space-4);
    padding: var(--space-3) var(--space-4);
    border: 1px solid color-mix(in srgb, var(--c-warm, var(--c-fix)) 45%, var(--c-line));
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--c-warm, var(--c-fix)) 10%, var(--c-surface));
    color: var(--c-text);
  }
  .cform {
    width: min(440px, 100%);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    text-align: left;
  }
  .cform__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  .cform__input {
    width: 100%;
    padding: var(--space-3);
    font: inherit;
    color: var(--c-text);
    background: var(--c-surface);
    border: 1px solid var(--c-line);
    border-radius: var(--radius);
    transition: border-color var(--dur-micro) var(--ease-settle);
  }
  .cform__input::placeholder { color: var(--c-muted); }
  .cform__input:focus-visible {
    outline: none;
    border-color: color-mix(in srgb, var(--c-fix) 60%, var(--c-line));
  }
  .cform__msg { resize: vertical; min-height: 7rem; }
  .cform__send {
    justify-self: start;
    align-self: center;
    margin-top: var(--space-1);
  }
  @media (max-width: 520px) {
    .cform__row { grid-template-columns: 1fr; }
  }
</style>

<script>
  // After Formspree redirects back with ?sent=1, reveal the thank-you note and
  // tidy the URL so a refresh doesn't keep showing it.
  if (new URLSearchParams(location.search).get('sent') === '1') {
    const note = document.querySelector('[data-contact-sent]');
    if (note) {
      note.removeAttribute('hidden');
      note.scrollIntoView({ block: 'center', behavior: 'smooth' });
    }
    const url = new URL(location.href);
    url.searchParams.delete('sent');
    history.replaceState(null, '', url.pathname + url.hash);
  }
</script>
