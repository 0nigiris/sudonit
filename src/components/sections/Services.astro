---
/**
 * Services — the "hire-me-now" verbs (Fix + Teach), given primacy.
 * Cards from the content model; warm primary CTA (Fix my computer -> WhatsApp).
 */
import { type Locale } from '../../data/site';
import { getServices, PHOTO_BY_KEY } from '../../lib/content';
import { localePath } from '../../lib/paths';
import { homeT } from '../../i18n/home';
import { t } from '../../i18n/ui';
import { whatsappLink } from '../../data/contact';
import VerbCard from '../VerbCard.astro';

interface Props { locale: Locale }
const { locale } = Astro.props;
const services = await getServices(locale);
---

<section class="section" id="services">
  <div class="container">
    <p class="eyebrow" data-reveal>{homeT(locale, 'services.eyebrow')}</p>
    <h2 class="section__title" data-reveal>{homeT(locale, 'services.title')}</h2>

    <p class="services__note" data-reveal>{homeT(locale, 'services.note')}</p>

    <div class="cards2" data-reveal-group>
      {
        services.map((s) => (
          <VerbCard
            verb={s.data.verb}
            name={s.data.name}
            oneLine={s.data.oneLine}
            href={localePath(locale, s.data.key)}
            photoId={PHOTO_BY_KEY[s.data.key]}
            cta={t(locale, 'showcase.viewProject')}
          />
        ))
      }
    </div>

    <p class="services__cta" data-reveal>
      <a class="cta cta--warm" href={whatsappLink()} target="_blank" rel="noopener noreferrer">
        {t(locale, 'contact.primaryRepair')} →
      </a>
    </p>
  </div>
</section>

<style>
  .services__note {
    max-width: var(--measure);
    margin: var(--space-3) 0 var(--space-5);
    padding: var(--space-3) var(--space-4);
    border-left: 3px solid var(--c-light);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--c-light) 9%, transparent);
    color: var(--c-text);
    font-size: var(--fs-small);
    line-height: var(--lh-body);
    text-wrap: pretty;
  }
  .services__cta {
    margin-top: var(--space-5);
  }
</style>
