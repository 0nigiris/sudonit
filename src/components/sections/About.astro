---
/**
 * About — Who (the person) + Why (how he thinks, NOT biography).
 * The Why pull-quote is the emotional beat of the page.
 */
import { type Locale } from '../../data/site';
import { homeT } from '../../i18n/home';
import PhotoFrame from '../PhotoFrame.astro';

interface Props { locale: Locale }
const { locale } = Astro.props;
---

<section class="section about" id="about">
  <div class="container">
    {/* WHO */}
    <div class="about__who">
      <PhotoFrame id="A2" ratio="4 / 5" class="about__photo" />
      <div>
        <p class="eyebrow">{homeT(locale, 'who.eyebrow')}</p>
        <p class="about__lead">{homeT(locale, 'who.lead')}</p>
        <p class="about__body">{homeT(locale, 'who.body')}</p>
      </div>
    </div>

    {/* WHY — the pull-quote */}
    <div class="about__why">
      <p class="eyebrow">{homeT(locale, 'why.eyebrow')}</p>
      <blockquote class="about__quote">{homeT(locale, 'why.quote')}</blockquote>
      <p class="about__body">{homeT(locale, 'why.body')}</p>
    </div>
  </div>
</section>

<style>
  .about__who {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: var(--space-6);
    align-items: center;
  }
  .about__photo {
    max-width: 360px;
  }
  .about__lead {
    font-size: var(--fs-h2);
    font-family: var(--font-display);
    line-height: var(--lh-snug);
    margin-bottom: var(--space-3);
  }
  .about__body {
    color: var(--c-muted);
    max-width: var(--measure);
  }
  .about__why {
    margin-top: var(--space-8);
    text-align: center;
  }
  .about__quote {
    font-family: var(--font-display);
    font-size: var(--fs-h1);
    line-height: var(--lh-snug);
    max-width: 22ch;
    margin: var(--space-3) auto var(--space-3);
    text-wrap: balance;
  }
  .about__why .about__body {
    margin-inline: auto;
  }
  @media (max-width: 760px) {
    .about__who {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .about__photo {
      max-width: 320px;
    }
  }
</style>
