---
/**
 * Hero — meet Alexander in one breath: who he is, what he does, and the promise
 * that removes the risk of reaching out. Person-first (the name leads), with the
 * verb spine (Fix · Teach · Build · Create) and a bold, warm-lit portrait.
 * Above the fold = the LCP element: it paints instantly, never gated by JS.
 */
import { type Locale } from '../../data/site';
import { homeT } from '../../i18n/home';
import { t } from '../../i18n/ui';
import { whatsappLink } from '../../data/contact';
import PhotoFrame from '../PhotoFrame.astro';

interface Props { locale: Locale }
const { locale } = Astro.props;
---

<section class="hero">
  <div class="container hero__grid">
    <div class="hero__text">
      <p class="hero__kicker">{homeT(locale, 'hero.kicker')}</p>

      <h1 class="hero__name">{homeT(locale, 'hero.name')}</h1>

      <p class="hero__lead">{homeT(locale, 'hero.lead')}</p>

      <p class="hero__trust">
        <svg class="hero__check" viewBox="0 0 24 24" width="18" height="18" fill="none"
          stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 12.5l5 5L20 6" />
        </svg>
        <span>{homeT(locale, 'hero.trust')}</span>
      </p>

      <div class="hero__actions">
        <a class="cta cta--warm" href={whatsappLink()} target="_blank" rel="noopener noreferrer">
          {t(locale, 'contact.whatsapp')}
        </a>
        <a class="cta cta--ghost" href="#services">
          {homeT(locale, 'hero.ctaSecondary')} ↓
        </a>
      </div>
    </div>

    <div class="hero__portrait">
      <PhotoFrame id="A1" ratio="4 / 5" position="center top" tint="var(--c-light)"
        alt={homeT(locale, 'hero.portraitAlt')} priority class="hero__photo" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: var(--space-7) var(--space-6);
  }
  .hero__grid {
    display: grid;
    grid-template-columns: 1.05fr minmax(300px, 440px);
    gap: var(--space-6);
    align-items: center;
  }

  .hero__kicker {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--c-light);
    margin-bottom: var(--space-3);
  }

  .hero__name {
    font-size: var(--fs-display);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: -0.035em;
    /* A lit gradient with a movable specular band. At REST the highlight is
       parked upper-left (18%) — matching the lamp that pools from the top-left
       (--lamp's 8% -6% source), so the name reads as lit even with no motion.
       The entrance sweeps this band across once (see hero-name-sweep). */
    background: linear-gradient(
      100deg,
      var(--c-text) 0%,
      color-mix(in srgb, var(--c-text) 86%, var(--c-light)) 30%,
      var(--c-light-hi) 50%,
      color-mix(in srgb, var(--c-text) 86%, var(--c-light)) 70%,
      var(--c-text) 100%
    );
    background-size: 250% 100%;
    background-position: 18% 0;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero__lead {
    margin-top: var(--space-4);
    max-width: 42ch;
    font-size: var(--fs-lead);
    line-height: var(--lh-snug);
    color: var(--c-text);
    text-wrap: pretty;
  }

  .hero__trust {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-top: var(--space-4);
    padding: 0.6em 1em 0.6em 0.8em;
    border: 1px solid color-mix(in srgb, var(--c-light) 30%, var(--c-line));
    border-radius: 999px;
    background: color-mix(in srgb, var(--c-light) 7%, transparent);
    color: var(--c-text);
    font-size: var(--fs-small);
    line-height: 1.35;
    text-wrap: pretty;
  }
  .hero__check {
    flex: none;
    color: var(--c-light);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }

  /* Portrait: a warm light bloom behind it so the figure feels lit by the lamp. */
  .hero__portrait {
    position: relative;
    isolation: isolate;
  }
  .hero__portrait::before {
    content: '';
    position: absolute;
    inset: -12% -8% -4% -8%;
    z-index: -1;
    background: radial-gradient(60% 55% at 60% 18%,
      color-mix(in srgb, var(--c-light) 26%, transparent), transparent 70%);
    filter: blur(8px);
  }
  .hero__portrait :global(.hero__photo) {
    box-shadow: var(--shadow-lg);
  }
  .hero__portrait :global(.hero__photo .photo__img),
  .hero__portrait :global(.hero__photo .photo__inner) {
    border-radius: var(--radius-lg);
  }

  /* ============================================================
     Cinematic entrance — the second focus-pole (the first is /glasses).
     "The lamp turns on over the workbench": the portrait lights up first
     (it is the light source), a specular band sweeps once across the name,
     and the text rises into the light in one choreographed beat (~1.3s).

     Contract (matches motion.css):
     - Armed ONLY under `.js` (set inline in <head> before paint) — so no-JS
       users get the final, fully-lit static frame with zero flash.
     - `both` fill holds the from-state during each delay (nothing flashes in
       early) and pins the to-state after (nothing snaps back).
     - Nothing essential is hidden past ~0.7s, so the LCP name paints fast.
     - Reduced motion = the complete static frame (handled below).
     ============================================================ */
  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: none; }
  }
  @keyframes hero-portrait-in {
    from { opacity: 0; transform: translateY(16px) scale(0.965); }
    to   { opacity: 1; transform: none; }
  }
  /* The lamp warming up behind the figure. */
  @keyframes hero-glow-in {
    from { opacity: 0; transform: scale(0.9); }
    to   { opacity: 1; transform: none; }
  }
  /* One specular pass: band travels from off-right to its upper-left rest. */
  @keyframes hero-name-sweep {
    from { background-position: 135% 0; }
    to   { background-position: 18% 0; }
  }

  .js .hero__portrait { animation: hero-portrait-in 760ms var(--ease-settle) both 60ms; }
  .js .hero__portrait::before { animation: hero-glow-in 900ms var(--ease-settle) both 40ms; }
  .js .hero__kicker { animation: hero-rise 520ms var(--ease-settle) both 120ms; }
  .js .hero__name {
    animation:
      hero-rise 560ms var(--ease-settle) both 160ms,
      hero-name-sweep 1000ms var(--ease-settle) both 360ms;
  }
  .js .hero__lead { animation: hero-rise 560ms var(--ease-settle) both 360ms; }
  .js .hero__trust { animation: hero-rise 560ms var(--ease-settle) both 460ms; }
  .js .hero__actions { animation: hero-rise 560ms var(--ease-settle) both 560ms; }

  /* Reduced motion = the complete frame: lit, present, unmoved, no sweep. */
  @media (prefers-reduced-motion: reduce) {
    .js .hero__portrait,
    .js .hero__portrait::before,
    .js .hero__kicker,
    .js .hero__name,
    .js .hero__lead,
    .js .hero__trust,
    .js .hero__actions {
      animation: none !important;
    }
  }

  @media (max-width: 900px) {
    .hero {
      padding-block: var(--space-6) var(--space-5);
    }
    .hero__grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    .hero__portrait {
      max-width: 420px;
    }
  }
</style>
