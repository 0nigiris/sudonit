---
/**
 * HowItWorks — three honest steps from "you write" to "it works". Removes the
 * fear of "how do I even order this". Static, no JS. Copy kept local (like
 * Contact's FORM_COPY) so it stays out of the typed i18n union.
 */
import { type Locale } from '../../data/site';

interface Props { locale: Locale }
const { locale } = Astro.props;

const COPY: Record<Locale, { eyebrow: string; title: string; steps: { t: string; d: string }[] }> = {
  ru: {
    eyebrow: 'Как это происходит',
    title: 'Прозрачно с первого сообщения',
    steps: [
      { t: 'Заявка', d: 'Опишите задачу удобным способом — WhatsApp, Telegram или форма. Фотографии помогут быстрее понять ситуацию.' },
      { t: 'Оценка', d: 'Уточняю детали и заранее называю стоимость и срок. Вы соглашаетесь до начала работы.' },
      { t: 'Результат', d: 'Выполняю работу и показываю результат. Оплата — когда всё работает как нужно.' },
    ],
  },
  en: {
    eyebrow: 'How it works',
    title: 'Clear from the first message',
    steps: [
      { t: 'Request', d: 'Describe the task however suits you — WhatsApp, Telegram or the form. Photos help me understand it faster.' },
      { t: 'Estimate', d: 'I clarify the details and give you the price and timeframe in advance. You agree before any work begins.' },
      { t: 'Result', d: 'I do the work and show you the result. You pay once everything works as it should.' },
    ],
  },
  es: {
    eyebrow: 'Cómo funciona',
    title: 'Claro desde el primer mensaje',
    steps: [
      { t: 'Solicitud', d: 'Describe la tarea como te resulte cómodo — WhatsApp, Telegram o el formulario. Las fotos ayudan a entenderla antes.' },
      { t: 'Presupuesto', d: 'Aclaro los detalles y te doy el precio y el plazo por adelantado. Aceptas antes de empezar.' },
      { t: 'Resultado', d: 'Hago el trabajo y te muestro el resultado. Pagas cuando todo funciona como debe.' },
    ],
  },
};
const c = COPY[locale];
---

<section class="section section--ruled how" id="how">
  <div class="container">
    <div class="section__head">
      <p class="eyebrow" data-reveal>{c.eyebrow}</p>
      <h2 class="section__title" data-reveal>{c.title}</h2>
    </div>

    <ol class="how__steps" data-reveal-group>
      {
        c.steps.map((step, i) => (
          <li class="how__step">
            <span class="how__num">{i + 1}</span>
            <h3 class="how__t">{step.t}</h3>
            <p class="how__d">{step.d}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .how__steps {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    margin-top: var(--space-3);
    counter-reset: step;
  }
  .how__step {
    position: relative;
    padding: var(--space-5) var(--space-4) var(--space-4);
    background: var(--c-surface);
    border: 1px solid var(--c-line);
    border-radius: var(--radius-lg);
  }
  /* A faint connecting tick at the top-left of each card — a quiet progression. */
  .how__step::before {
    content: '';
    position: absolute;
    top: 0;
    left: var(--space-4);
    width: 2.5rem;
    height: 2px;
    background: var(--c-light);
  }
  .how__num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    margin-bottom: var(--space-3);
    border-radius: 999px;
    background: color-mix(in srgb, var(--c-light) 14%, transparent);
    border: 1px solid color-mix(in srgb, var(--c-light) 30%, transparent);
    color: var(--c-light);
    font-family: var(--font-mono);
    font-size: 1.05rem;
    font-weight: 600;
  }
  .how__t {
    font-size: var(--fs-h3);
    margin-bottom: var(--space-2);
  }
  .how__d {
    color: var(--c-muted);
    line-height: var(--lh-body);
    text-wrap: pretty;
    max-width: 34ch;
  }
  @media (max-width: 760px) {
    .how__steps {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
</style>
