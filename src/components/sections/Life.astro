---
/**
 * Life — "Beyond tech". A warm, human breather between Why and Services:
 * Alexander as a person (drawing, anime, music) + the YouTube channel.
 * Light by design — NOT a CTA. The real contact close lives in Contact.
 */
import { type Locale } from '../../data/site';
import { homeT } from '../../i18n/home';
import { contact } from '../../data/contact';

interface Props { locale: Locale }
const { locale } = Astro.props;
---

<section class="section life" id="life">
  <div class="container life__inner" data-reveal>
    <p class="eyebrow">{homeT(locale, 'life.eyebrow')}</p>
    <p class="life__body">{homeT(locale, 'life.body')}</p>
    <a class="life__link" href={contact.youtube} target="_blank" rel="noopener noreferrer">
      {homeT(locale, 'life.youtube')}
      <span class="life__arrow" aria-hidden="true">→</span>
    </a>
  </div>
</section>

<style>
  .life__inner {
    max-width: 56ch;
  }
  .life__body {
    font-size: var(--fs-lead);
    line-height: var(--lh-body);
    color: var(--c-text);
    margin-block: var(--space-3) var(--space-4);
    text-wrap: pretty;
  }
  .life__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--fs-small);
    color: var(--c-muted);
    transition: color var(--dur-micro) var(--ease-settle);
  }
  .life__link:hover {
    color: var(--c-text);
  }
  .life__arrow {
    transition: transform var(--dur-micro) var(--ease-settle);
  }
  .life__link:hover .life__arrow {
    transform: translateX(3px);
  }
</style>
