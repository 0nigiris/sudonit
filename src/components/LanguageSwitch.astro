---
/**
 * LanguageSwitch — quiet RU/EN/ES control. Not a menu, not a dropdown to learn.
 * Pure links (works with no JS). Highlights the active locale.
 */
import { LOCALES, type Locale } from '../data/site';
import { localePath, barePath } from '../lib/paths';

interface Props {
  current: Locale;
  landmark?: boolean; // true = a labelled <nav> landmark; false = plain group
}
const { current, landmark = true } = Astro.props;
// Avoid two identically-named "Language" nav landmarks (header + footer):
// the secondary instance renders as a non-landmark group.
const Wrapper = landmark ? 'nav' : 'div';

// Keep the visitor on the same page when switching language.
const bare = barePath(Astro.url.pathname);
const localeHref = (locale: Locale) => localePath(locale, bare);
---

<Wrapper class="lang" aria-label={landmark ? 'Language' : undefined}>
  {
    LOCALES.map((locale) => (
      <a
        href={localeHref(locale)}
        hreflang={locale}
        class:list={['lang__item', { 'is-active': locale === current }]}
        aria-current={locale === current ? 'true' : undefined}
      >
        {locale.toUpperCase()}
      </a>
    ))
  }
</Wrapper>

<style>
  /* Liquid-glass capsule: one translucent, blurred pill holding RU · EN · ES.
     The active locale rides a brighter glass segment. Pure CSS, no JS. */
  .lang {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    padding: 3px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--c-base) 55%, transparent);
    border: 1px solid color-mix(in srgb, var(--c-line) 80%, transparent);
    -webkit-backdrop-filter: saturate(160%) blur(10px);
    backdrop-filter: saturate(160%) blur(10px);
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
  }
  .lang__item {
    position: relative;
    color: var(--c-muted);
    padding: 4px 11px;
    border-radius: 999px;
    line-height: 1;
    transition:
      color var(--dur-micro) var(--ease-settle),
      background-color var(--dur-micro) var(--ease-settle);
  }
  .lang__item:hover {
    color: var(--c-text);
    background: color-mix(in srgb, var(--c-light) 8%, transparent);
  }
  /* The active segment — the brighter "glass" pill with a soft top highlight. */
  .lang__item.is-active {
    color: var(--c-text);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--c-light) 16%, transparent),
      color-mix(in srgb, var(--c-light) 9%, transparent)
    );
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--c-light) 22%, transparent),
      0 1px 3px color-mix(in srgb, #000 35%, transparent);
  }
  @media (prefers-reduced-motion: reduce) {
    .lang__item { transition: none; }
  }
</style>
