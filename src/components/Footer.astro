---
/**
 * Footer — quiet wrap. Channel · languages · Alicante · tiny onigiri easter egg.
 */
import { type Locale } from '../data/site';
import { SITE } from '../data/site';
import { contact } from '../data/contact';
import { t } from '../i18n/ui';
import LanguageSwitch from './LanguageSwitch.astro';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <span class="footer__name">{SITE.name}</span>
      <span class="footer__meta">{SITE.location} · RU / EN / ES</span>
    </div>

    <div class="footer__links">
      <a href={contact.youtube} target="_blank" rel="noopener noreferrer">@{SITE.youtubeHandle}</a>
      {/* onigiri — a tiny presence, not a mascot */}
      <span class="footer__cat" title="onigiri" aria-hidden="true">🐱</span>
    </div>

    <div class="footer__lang">
      <LanguageSwitch current={locale} />
    </div>
  </div>
  <div class="container footer__legal">
    <span>© {year} {SITE.owner}</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--c-line);
    padding-block: var(--space-6) var(--space-4);
    margin-top: var(--space-8);
    color: var(--c-muted);
  }
  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
    justify-content: space-between;
  }
  .footer__name {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--c-text);
    margin-right: var(--space-3);
  }
  .footer__meta {
    font-size: var(--fs-small);
  }
  .footer__links {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--fs-small);
  }
  .footer__links a:hover {
    color: var(--c-text);
  }
  .footer__legal {
    margin-top: var(--space-4);
    font-size: var(--fs-label);
  }
</style>
