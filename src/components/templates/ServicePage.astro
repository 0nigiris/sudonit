---
/**
 * ServicePage — dedicated page for a "hire-me-now" service (Repair, Tutoring).
 * Product-page feel: problem -> approach, what you get / how it works, then the
 * action block (Repair = request a quote; Tutoring = pricing tiers placeholder).
 * Static, content-first. Body prose comes from the content collection.
 */
import type { CollectionEntry } from 'astro:content';
import { type Locale } from '../../data/site';
import { VERB_META, tint } from '../../data/verbs';
import { PHOTO_BY_KEY } from '../../lib/content';
import { pageT } from '../../i18n/pages';
import { t } from '../../i18n/ui';
import { whatsappLink } from '../../data/contact';
import PageHero from '../PageHero.astro';
import ContactStrip from '../ContactStrip.astro';

interface Props {
  entry: CollectionEntry<'services'>;
  locale: Locale;
}
const { entry, locale } = Astro.props;
const { name, oneLine, verb, key, pricing, tiers, priceNote, problem, approach, whatYouGet, howItWorks } =
  entry.data;

// A tier is expandable if it carries any detail to reveal on click.
const isExpandable = (tr: (typeof tiers extends undefined ? never : NonNullable<typeof tiers>)[number]) =>
  !!(tr.when?.length || tr.what?.length || tr.gives?.length);
const hasExpandable = pricing === 'tiers' && !!tiers?.some(isExpandable);
---

<PageHero
  locale={locale}
  eyebrow={VERB_META[verb].label}
  tint={tint(verb)}
  name={name}
  oneLine={oneLine}
  photoId={PHOTO_BY_KEY[key] ?? 'B1'}
/>

<section class="section">
  <div class="container">
    <div class="page-grid" data-reveal-group>
      <div class="pblock">
        <h2>{pageT(locale, 'svc.problem')}</h2>
        <p>{problem ?? pageT(locale, 'placeholder')}</p>
      </div>
      <div class="pblock">
        <h2>{pageT(locale, 'svc.approach')}</h2>
        <p>{approach ?? pageT(locale, 'placeholder')}</p>
      </div>
    </div>

    <div class="page-grid svc__second" data-reveal-group>
      <div class="pblock">
        <h2>{pageT(locale, 'svc.whatYouGet')}</h2>
        <p>{whatYouGet ?? pageT(locale, 'placeholder')}</p>
      </div>
      <div class="pblock">
        <h2>{pageT(locale, 'svc.howItWorks')}</h2>
        <p>{howItWorks ?? pageT(locale, 'placeholder')}</p>
      </div>
    </div>

    {/* Action block: quote vs pricing tiers */}
    <div class="svc__action" style={`--tint:${tint(verb)}`} data-reveal>
      <h2>{pageT(locale, 'svc.pricing')}</h2>

      {pricing === 'tiers' && tiers && tiers.length > 0 ? (
        <>
          {hasExpandable && <p class="tiers__hint">{pageT(locale, 'svc.detailHint')}</p>}
          <ul class="tiers" role="list">
            {tiers.map((tier, i) => (
              <>
                {tier.group && tier.group !== tiers[i - 1]?.group && (
                  <li class="tier__group">{tier.group}</li>
                )}
                {isExpandable(tier) ? (
                  <li class="tier tier--exp">
                    <details class="tdet">
                      <summary class="tdet__sum">
                        <span class="tier__name">{tier.name}</span>
                        <span class="tdet__meta">
                          <span class="tier__price">{tier.price ?? '—'}</span>
                          <span class="tdet__chev" aria-hidden="true">›</span>
                        </span>
                      </summary>
                      <div class="tdet__body">
                        {tier.when && tier.when.length > 0 && (
                          <div class="tdet__col">
                            <h4 class="tdet__h">{pageT(locale, 'svc.detailWhen')}</h4>
                            <ul class="tdet__list">{tier.when.map((x) => <li>{x}</li>)}</ul>
                          </div>
                        )}
                        {tier.what && tier.what.length > 0 && (
                          <div class="tdet__col">
                            <h4 class="tdet__h">{pageT(locale, 'svc.detailWhat')}</h4>
                            <ul class="tdet__list">{tier.what.map((x) => <li>{x}</li>)}</ul>
                          </div>
                        )}
                        {tier.gives && tier.gives.length > 0 && (
                          <div class="tdet__col">
                            <h4 class="tdet__h">{pageT(locale, 'svc.detailGives')}</h4>
                            <ul class="tdet__gives">
                              {tier.gives.map((g) => (
                                <li>
                                  <span class="tdet__gt">{g.t}</span>
                                  <span class="tdet__gd">{g.d}</span>
                                </li>
                              ))}
                            </ul>
                          </div>
                        )}
                      </div>
                    </details>
                  </li>
                ) : (
                  <li class="tier">
                    <span class="tier__name">{tier.name}</span>
                    {tier.detail && <span class="tier__detail">{tier.detail}</span>}
                    <span class="tier__price">{tier.price ?? '—'}</span>
                  </li>
                )}
              </>
            ))}
          </ul>
          <p class="svc__quote-note">{priceNote ?? pageT(locale, 'svc.quoteNote')}</p>
        </>
      ) : (
        <p class="svc__quote-note">{pageT(locale, 'svc.quoteNote')}</p>
      )}

      <a class="cta cta--warm" href={whatsappLink()} target="_blank" rel="noopener noreferrer">
        {pricing === 'tiers' ? t(locale, 'contact.whatsapp') : pageT(locale, 'svc.requestQuote')} →
      </a>
    </div>
  </div>
</section>

<ContactStrip locale={locale} />

<style>
  .svc__second {
    margin-top: var(--space-6);
  }
  .svc__action {
    margin-top: var(--space-7);
    padding: var(--space-5);
    border: 1px solid var(--c-line);
    border-top: 3px solid var(--tint);
    border-radius: var(--radius-lg);
    background: var(--c-surface);
  }
  .svc__action h2 {
    font-size: var(--fs-h2);
    margin-bottom: var(--space-4);
  }
  .svc__quote-note {
    color: var(--c-muted);
    max-width: var(--measure);
    margin-bottom: var(--space-4);
  }
  .tiers {
    display: grid;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }
  .tier__group {
    grid-column: 1 / -1;
    margin-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--tint);
  }
  .tier__group:first-child { margin-top: 0; }
  .tier {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: var(--space-1) var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--c-line);
  }
  .tier__name {
    font-family: var(--font-display);
    font-size: var(--fs-lead);
  }
  .tier__detail {
    grid-column: 1;
    color: var(--c-muted);
    font-size: var(--fs-small);
  }
  .tier__price {
    grid-column: 2;
    grid-row: 1 / span 2;
    font-family: var(--font-mono);
    color: var(--tint);
  }

  /* Expandable tier (click to reveal detail) */
  .tiers__hint {
    color: var(--c-muted);
    font-size: var(--fs-small);
    margin-bottom: var(--space-4);
  }
  .tier--exp {
    display: block;
    padding-bottom: 0;
    border-bottom: 1px solid var(--c-line);
  }
  .tdet__sum {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: var(--space-3);
    padding: var(--space-2) 0 var(--space-3);
    cursor: pointer;
    list-style: none;
  }
  .tdet__sum::-webkit-details-marker { display: none; }
  .tdet__sum:hover .tier__name,
  .tdet__sum:focus-visible .tier__name { color: var(--tint); }
  .tdet__sum .tier__price { grid-row: auto; }
  .tdet__meta {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
  }
  .tdet__chev {
    font-family: var(--font-mono);
    color: var(--c-muted);
    transition: transform 0.2s ease;
  }
  .tdet[open] .tdet__chev { transform: rotate(90deg); }
  .tdet__body {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: var(--space-4);
    padding: var(--space-2) 0 var(--space-4);
  }
  .tdet__h {
    font-family: var(--font-mono);
    font-size: var(--fs-label);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--tint);
    margin-bottom: var(--space-2);
  }
  .tdet__list,
  .tdet__gives {
    list-style: none;
    display: grid;
    gap: var(--space-1);
  }
  .tdet__gives { gap: var(--space-2); }
  .tdet__list li {
    position: relative;
    padding-left: 1.1em;
    color: var(--c-muted);
    font-size: var(--fs-small);
  }
  .tdet__list li::before {
    content: '–';
    position: absolute;
    left: 0;
    color: var(--tint);
  }
  .tdet__gt {
    display: block;
    color: var(--c-text);
    font-weight: 600;
  }
  .tdet__gd {
    display: block;
    color: var(--c-muted);
    font-size: var(--fs-small);
  }
  @media (prefers-reduced-motion: reduce) {
    .tdet__chev { transition: none; }
  }
</style>
